{
  "version": 2,
  "public": true,
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/careers.html",
      "destination": "/careers",
      "statusCode": 301
    },
    {
      "source": "/2018/08/23/the-journey-begins",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/2018/08/23/the-journey-begins/",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/2018/(.*)",
      "destination": "/",
      "statusCode": 301
    }
  ],
  "functions": {
    "api/admin.js": {
      "maxDuration": 30
    },
    "api/careers.js": {
      "maxDuration": 30
    },
    "api/contact.js": {
      "maxDuration": 30
    },
    "api/events.js": {
      "maxDuration": 10
    },
    "api/metrics.js": {
      "maxDuration": 10
    },
    "api/route-estimate.js": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/api/admin/:path*",
      "destination": "/api/admin?path=:path*"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ]
}
