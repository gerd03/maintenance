PORT=3000
RESEND_API_KEY=

# Admin CRM auth (keep private, never expose in frontend)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=System Admin

# Supabase CRM backend
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Optional: use service-role key for stronger server-side permissions.
# SUPABASE_SERVICE_ROLE_KEY=
# Optional: publishable key fallback if you use the new key format.
# SUPABASE_PUBLISHABLE_KEY=

# Route provider selection:
# auto | google | tomtom | osrm
ROUTE_API_PROVIDER=auto

# Optional traffic-aware providers:
GOOGLE_MAPS_API_KEY=
TOMTOM_API_KEY=

# Google Routes traffic model:
# pessimistic | best_guess | optimistic
ROUTE_GOOGLE_TRAFFIC_MODEL=pessimistic
